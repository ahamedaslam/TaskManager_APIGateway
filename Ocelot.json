//Auth Endpoints Ocelot configuration
{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/{everything}", //this is what ocelot forwards to downstream service
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7001
        }
      ],
      "UpstreamPathTemplate": "/gateway/auth/{everything}", //this is what client calls //everything is a placeholder for any path after auth
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7000"
  }
}
