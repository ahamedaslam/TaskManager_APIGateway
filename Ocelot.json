{
  "Routes": [


    // #region ================== Auth Service ==================

    {
      "UpstreamPathTemplate": "/gateway/auth/{everything}", //client calls here
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
      "DownstreamPathTemplate": "/api/auth/{everything}", //gateway calls here
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7001
        }
      ]
    },

    // #endregion

    // #region ================== Task Manager Service ==================

    {
      "UpstreamPathTemplate": "/gateway/taskmanager/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "PATCH", "DELETE" ],
      "DownstreamPathTemplate": "/api/taskmanager/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7002
        }
      ]
    }

    // #endregion

  ],

  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7000"
  }
}