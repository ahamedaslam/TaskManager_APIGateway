{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/login", // Ocelot gateway will forward the request to the actual service using this endpoint
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7001
        }
      ],
      "UpstreamPathTemplate": "/gateway/auth/login", // Client will call this endpoint
      "UpstreamHttpMethod": [ "POST" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7000"
  }
}